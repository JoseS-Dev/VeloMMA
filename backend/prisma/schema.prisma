// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enum del tipo de género
enum Gender {
  Masculino
  Femenino
  Otro
}

// Enum del tipo de estancia
enum Stance {
  Orthodox
  Southpaw
  Switch
  Open_Stance
}

// Enum del resultado de la pelea
enum BoutResult {
  Win_Red
  Win_Blue
  Draw
  No_Contest
}

// Enum del metodo de victoria
enum WinMethod {
  KO
  TKO
  Submission
  Unanimous_Decision
  Split_Decision
  Majority_Decision
  Doctor_Stoppage
  Disqualification
}

// Enum del tipo de bono
enum BonusType {
  Fight_of_the_night
  Performance_of_the_night
  Submission_of_the_night
  Knockout_of_the_night
}

// Enum del tipo de lesión
enum InjurySeverity {
  Menor
  Moderado
  Severo
  Critica
}

// Enum del estado de la pelea
enum BoutStatus {
  Programada
  Cancelada
  En_Proceso
  Finalizada
}

// Enum para el tipo de Titulo
enum TitleType {
  Undisputed
  Interino
  Vacante
}

// Enum para el tipo de submissión
enum SubmissionType {
  Rear_Naked_Choke
  Guillotine_Choke
  Armbar
  Triangle_Choke
  Kimura
  Americana
  Ankle_Lock
  Heel_Hook
  Kneebar
  Wrist_Lock
  Other
}

// Tabla de los luchadores
model fighters {
  id Int @id @default(autoincrement())
  first_name String
  last_name String
  nickname String?
  slug String @unique
  birth_date DateTime?
  gender Gender?
  nationality String?
  height Float?
  weight Float?
  stance Stance?
  reach Float?
  is_active Boolean @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?
  divisions fighterDivision[]
  teams fighterTeams[]
  injuries fighterInjuries[]
  boutsWeights boutWeighIns[]
  bouts_red bouts[] @relation("RedCorner")
  metrics boutMetrics[]
  bouts_blue bouts[] @relation("BlueCorner")
  rankings fighterRankings[]
  bonuses boutBonuses[]
  titles fighterTitles[]
  camps trainingCamps[]
  stats fighterStats?
  @@map("fighters")
}

// Tabla de lesiones o inactividades de un luchador
model fighterInjuries {
  id Int @id @default(autoincrement())
  fighter_id Int
  description_injury String
  severity_injury InjurySeverity
  injury_date DateTime?
  recovery_date DateTime?
  is_active Boolean @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?
  fighter fighters @relation(fields: [fighter_id], references: [id])
  @@map("fighter_injuries")
}

// Tabla de las divisiones de pesos de los luchadores
model divisions {
  id Int @id @default(autoincrement())
  name_division String
  weight_class String
  gender Gender
  is_active Boolean @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?
  fighters fighterDivision[]
  bouts bouts[]
  rankings fighterRankings[]
  titles fighterTitles[]
  @@map("divisions")
}

// Tabla intermedia de la relación entre luchadores y divisiones
model fighterDivision {
  id Int @id @default(autoincrement())
  fighter_id Int
  division_id Int
  is_current Boolean @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?
  fighter fighters @relation(fields: [fighter_id], references: [id])
  division divisions @relation(fields: [division_id], references: [id])
  @@unique([fighter_id, division_id])
  @@map("fighter_division")
}

// Tabla de equipos
model teams {
  id Int @id @default(autoincrement())
  name_team String
  description_team String?
  date_founded DateTime?
  location String
  is_active Boolean @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?
  fighters fighterTeams[]
  camps trainingCamps[]
  @@map("teams")
}

// Tabla de los equipos de luchadores
model fighterTeams {
  id Int @id @default(autoincrement())
  fighter_id Int
  team_id Int
  is_current Boolean @default(false)
  joined_date DateTime?
  left_date DateTime?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?
  fighter fighters @relation(fields: [fighter_id], references: [id])
  team teams @relation(fields: [team_id], references: [id])
  @@map("fighter_teams")
}

// tabla de los eventos
model events {
  id Int @id @default(autoincrement())
  name_event String
  date_event DateTime
  location_event String
  venue_event String?
  octagon_size Float?
  is_active Boolean @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?
  bouts bouts[]
  @@map("events")
}

// Tabla de las peleas de un evento
model bouts {
  id Int @id @default(autoincrement())
  event_id Int
  division_id Int
  red_corner_id Int
  blue_corner_id Int
  result BoutResult?
  method WinMethod?
  submission_type SubmissionType?
  rounded_ended Int?
  time_ended Int?
  referee String?
  is_title_fight Boolean @default(false)
  upset Boolean @default(false)
  status_bout BoutStatus @default(Programada)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?
  event events @relation(fields: [event_id], references: [id])
  division divisions @relation(fields: [division_id], references: [id])
  red_corner fighters @relation("RedCorner" ,fields: [red_corner_id], references: [id])
  blue_corner fighters @relation("BlueCorner" ,fields: [blue_corner_id], references: [id])
  judges boutJudges[]
  metrics boutMetrics[]
  boutWeighIns boutWeighIns[]
  bonuses boutBonuses[]
  odds boutOdds[]
  camps trainingCamps[]
  @@map("bouts")
}

// Tabla de las metricas de la pelea de un luchador
model boutMetrics {
  id Int @id @default(autoincrement())
  bout_id Int
  fighter_id Int
  round Int
  sig_strikes_landed Int @default(0)
  sig_strikes_attempted Int @default(0)
  total_strikes_landed Int @default(0)
  total_strikes_attempted Int @default(0)
  head_strikes_landed Int @default(0)
  body_strikes_landed Int @default(0)
  leg_strikes_landed Int @default(0)
  takedowns_landed Int @default(0)
  takedowns_attempted Int @default(0)
  submissions_landed Int @default(0)
  head_strikes_attempted Int @default(0)
  body_strikes_attempted Int @default(0)
  leg_strikes_attempted Int @default(0)
  distance_strikes_landed Int @default(0)
  clinch_strikes_landed Int @default(0)
  ground_strikes_landed Int @default(0)
  distance_strikes_attempted Int @default(0)
  clinch_strikes_attempted Int @default(0)
  ground_strikes_attempted Int @default(0)
  reversals Int @default(0)
  control_time Int @default(0)
  knockdowns Int @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?
  bout bouts @relation(fields: [bout_id], references: [id])
  fighter fighters @relation(fields: [fighter_id], references: [id])
  @@unique([bout_id, fighter_id, round])
  @@map("bout_metrics")
}

// Tabla de los jueces de una pelea
model boutJudges {
  id Int @id @default(autoincrement())
  bout_id Int
  judge_name String
  red_score Int
  blue_score Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?
  bout bouts @relation(fields: [bout_id], references: [id])
  @@unique([bout_id, judge_name])
  @@map("bout_judges")
}

// Tabla de los pesajes oficiales de un luchador para una pelea
model boutWeighIns {
  id Int @id @default(autoincrement())
  bout_id Int
  fighter_id Int
  weight_recorded Float
  missed_weight Boolean @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?
  bout bouts @relation(fields: [bout_id], references: [id])
  fighter fighters @relation(fields: [fighter_id], references: [id])
  @@unique([bout_id, fighter_id])
  @@map("bout_weigh_ins")
}

// Modelo que representa la clasificación de los luchadores en una división
model fighterRankings {
  id Int @id @default(autoincrement())
  fighter_id Int
  division_id Int
  rank Int
  as_of_date DateTime
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?
  fighter fighters @relation(fields: [fighter_id], references: [id])
  division divisions @relation(fields: [division_id], references: [id])
  @@map("fighter_rankings")
}

// Modelo para los bonos de un luchador
model boutBonuses {
  id Int @id @default(autoincrement())
  bout_id Int
  fighter_id Int
  bonus_type BonusType
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?
  bout bouts @relation(fields: [bout_id], references: [id])
  fighter fighters @relation(fields: [fighter_id], references: [id])
  @@map("bout_bonuses")
}

// Modelo para el historial de los cinturones de un luchador
model fighterTitles {
  id Int @id @default(autoincrement())
  division_id Int
  fighter_id Int
  title_type TitleType @default(Undisputed)
  won_date DateTime
  lost_date DateTime?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?
  division divisions @relation(fields: [division_id], references: [id])
  fighter fighters @relation(fields: [fighter_id], references: [id])
  @@map("fighter_titles")
}

// Modelo para las casas de las apuentas por la pelea
model boutOdds {
  id Int @id @default(autoincrement())
  bout_id Int
  red_opening_odds Float
  blue_opening_odds Float
  red_closing_odds Float
  blue_closing_odds Float
  provider String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?
  bout bouts @relation(fields: [bout_id], references: [id])
  @@map("bout_odds")
}

// Modelo para el historial de campamentos de entrenamiento de un luchador para una pelea
model trainingCamps {
  id Int @id @default(autoincrement())
  bout_id Int
  team_id Int
  fighter_id Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?
  bout bouts @relation(fields: [bout_id], references: [id])
  team teams @relation(fields: [team_id], references: [id])
  fighter fighters @relation(fields: [fighter_id], references: [id])
  @@unique([bout_id, fighter_id])
  @@map("training_camps")
}

// Modelo para actaulización de las metricas de un luchador cada vez que termine un evento
model fighterStats {
  id Int @id @default(autoincrement())
  fighter_id Int @unique
  sig_strikes_accuracy Float
  sig_strikes_absorbed_pm Float
  takedown_accuracy Float
  takedown_defense Float
  average_fight_time Float
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?
  fighter fighters @relation(fields: [fighter_id], references: [id])
  @@map("fighter_stats")
}
