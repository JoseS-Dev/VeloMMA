  "files": ["dist"],
  "type": "module",
  "scripts": {
    "test": "echo \"No tests configured\"",
    "dev": "tsx watch app.ts",
    "prebuild": "rimraf dist",
    "build": "tsc",
    "start": "node dist/app.js",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:reset": "prisma migrate reset",
    "seed": "tsx ./src/core/seed.ts",
    "docker:migrate": "docker compose exec backend pnpm prisma migrate dev",
    "docker:generate": "docker compose exec backend pnpm prisma generate",
    "docker:reset": "docker compose exec backend pnpm prisma migrate reset",
    "docker:install": "docker compose exec backend pnpm install",
    "docker:seed": "docker compose exec backend pnpm ./src/core/seed.ts",
    "docker:start": "docker compose up -d",
    "docker:stop": "docker compose down"
  },
